# ── Local development ─────────────────────────────────────────────
# Copy to .env.local and fill in values:
#   cp .env.example .env.local
#
# Or pull from Vercel (requires Vercel CLI + project link):
#   vercel env pull .env.local
#
# ── Vercel (Production / Preview) ─────────────────────────────────
# Add the same keys in: Project → Settings → Environment Variables
#   STRAPI_URL         → your public Strapi URL (NOT http://localhost:1337)
#   STRAPI_API_TOKEN   → Strapi API token (check spelling — not STRIP_API_TOKEN)
# Then redeploy after saving variables.
#
# Strapi CMS (server-side only — never use NEXT_PUBLIC_ for the token)
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=your_strapi_api_token
